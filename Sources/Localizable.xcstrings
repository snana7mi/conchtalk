    "Host key mismatch for %@. Expected fingerprint %@, but received %@. This may indicate a man-in-the-middle attack.": {
      "comment": "Error message indicating a mismatch between the expected and actual host key during SSH connection setup. The first argument is the hostname. The second argument is the expected host key fingerprint. The third argument is the actual host key fingerprint.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Host key mismatch for %1$@. Expected fingerprint %2$@, but received %3$@. This may indicate a man-in-the-middle attack."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ のホスト鍵が一致しません。期待されるフィンガープリントは %2$@ ですが、%3$@ を受信しました。中間者攻撃の可能性があります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ 的主机密钥不匹配。期望的指纹为 %2$@，但收到的是 %3$@。这可能表明存在中间人攻击。"
          }
        }
      }
    },
    "Hostname": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hostname"
          }
        },
        "ja": {
