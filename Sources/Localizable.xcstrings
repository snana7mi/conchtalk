{
  "sourceLanguage": "en",
  "strings": {
    "": {},
    "#": {
      "comment": "A column header displaying the index of a process in the list.",
      "isCommentAutoGenerated": true
    },
    "$": {
      "comment": "A symbol used to indicate the start of a command in a terminal-like interface.",
      "isCommentAutoGenerated": true
    },
    "%@ / %@": {
      "comment": "A text displaying the used and total storage space of a disk, followed by the percentage of that space that is used. The first argument is the used storage space. The second argument is the total storage space. The third argument is the percentage of the total storage space that is used.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ / %2$@"
          }
        }
      }
    },
    "%@ connected": {
      "comment": "A text label indicating that a user is currently connected to a chat agent. The argument is the name of the agent.",
      "isCommentAutoGenerated": true
    },
    "%@ expired and removed": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ の有効期限が切れ、削除されました"
